      <hashTree>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer eyJhbGciOiJIUzM4NCJ9.eyJ1c2VySWQiOjEsInVzZXJuYW1lIjoiYWRtaW4iLCJzdWIiOiJhZG1pbiIsImlhdCI6MTc4NDAwNzgxNSwiZXhwIjoxNzg0MDk0MjE1fQ.ULIksYyoDjfjdQKZhjeFdp37wqlV9lCwilFBA7VsAg_v1OZm-5GBRwjUZDpLPo8e</stringProp>
